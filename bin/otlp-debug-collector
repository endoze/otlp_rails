#!/usr/bin/env bash
set -euo pipefail

# Runs a lightweight OpenTelemetry Collector that accepts OTLP over HTTP
# on port 4318 and prints all received metrics to the console.
#
# Usage:
#   ./bin/otlp-debug-collector
#
# Then in another terminal:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 bin/rails server

TMPCONFIG="$(mktemp)"
trap 'rm -f "$TMPCONFIG"' EXIT

cat >"$TMPCONFIG" <<'EOF'
receivers:
  otlp:
    protocols:
      http:
        endpoint: 0.0.0.0:4318

exporters:
  debug:
    verbosity: detailed

service:
  pipelines:
    metrics:
      receivers: [otlp]
      exporters: [debug]
    traces:
      receivers: [otlp]
      exporters: [debug]
EOF

echo "Starting OTLP debug collector on :4318 ..."
echo "Press Ctrl+C to stop."
echo ""

docker run --rm -p 4318:4318 \
  --name otlp-debug-collector \
  -v "$TMPCONFIG":/etc/otel/config.yaml:ro \
  otel/opentelemetry-collector-contrib:latest \
  --config /etc/otel/config.yaml
